   "source": [
    "START\n",
    "SET total = 0\n",
    "SET counting = \"yes\"\n",
    "    \n",
    "WHILE counting is \"yes\"\n",
    "    INPUT itemprice\n",
    "    total = total + itemprice\n",
    "        \n",
    "    INPUT \"Are you buying another item? (yes/no)\"\n",
    "    STORE answer in counting\n",
    "ENDWHILE\n",
    "PRINT total\n",
    "END\n",
    "![checkout.png](attachment:7de04340-c3c2-4a08-a2b0-8de5724e723f.png)"
   ]
